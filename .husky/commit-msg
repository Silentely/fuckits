#!/bin/sh
#
# commit-msg hook: 将提交信息写入临时文件，供 post-commit hook 替换 CHANGELOG 占位符
# （commit-msg 阶段无法可靠更新暂存区，改用 post-commit + amend）
#

COMMIT_MSG=$(head -1 "$1")

# 跳过 merge/revert commit
echo "$COMMIT_MSG" | grep -qE '^(Merge|Revert)' && exit 0

# 从提交信息中提取描述（去掉 conventional commit type 前缀）
DESC=$(echo "$COMMIT_MSG" | sed -E 's/^[a-z]+(\(.+\))?:[[:space:]]*//')
[ -z "$DESC" ] && DESC="$COMMIT_MSG"

# 写入临时文件供 post-commit hook 使用
echo "$DESC" > /tmp/.fuckits-commit-desc

exit 0
